# Copy to .env.obsidian on the Mac and replace the application password.
# Keep .env.obsidian private; it is ignored by .gitignore.

KB_PUBLIC_URL=https://kb.example.com
WP_KB_API_USER=codex-publisher
WP_KB_APP_PASSWORD=CHANGE_ME_AFTER_INIT

OBSIDIAN_VAULT_DIR=~/Documents/Obsidian/PersonalVault
OBSIDIAN_KB_DIR=个人知识库
