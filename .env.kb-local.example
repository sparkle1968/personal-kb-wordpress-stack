# Local-only personal knowledge base test site.
# Copy to .env.kb-local or run ./scripts/make-kb-local-env.sh.

KB_LOCAL_URL=http://localhost:8080
KB_LOCAL_DB_NAME=wordpress_kb_local
KB_LOCAL_DB_USER=wp_kb_local
KB_LOCAL_DB_PASSWORD=CHANGE_ME_KB_LOCAL_DB_PASSWORD
KB_LOCAL_DB_ROOT_PASSWORD=CHANGE_ME_KB_LOCAL_ROOT_PASSWORD

WP_ADMIN_USER=site-admin
WP_ADMIN_EMAIL=admin@example.com
WP_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
WP_PUBLISHER_USER=codex-publisher
WP_PUBLISHER_EMAIL=codex-publisher@example.com
WP_PUBLISHER_PASSWORD=CHANGE_ME_PUBLISHER_PASSWORD

WP_KB_API_USER=codex-publisher
WP_KB_APP_PASSWORD=CHANGE_ME_AFTER_INIT

