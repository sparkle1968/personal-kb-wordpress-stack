# Copy to .env on the Debian VM and replace every CHANGE_ME value.
#
# Recommended:
#   ./scripts/make-env.sh
#
# Domains
DOMAIN_KB=kb.example.com
DOMAIN_FAMILY=family.example.com
LETSENCRYPT_EMAIL=admin@example.com

# Optional. Use this when the public site URL includes a non-standard port,
# for example https://kb.example.com:4433.
KB_PUBLIC_URL=

# Cloudflare Tunnel. Use this when deploying with compose.kb-cloudflare.yml.
# Keep this secret; anyone with the token can run a replica of the tunnel.
CLOUDFLARE_TUNNEL_TOKEN=

# WordPress database settings
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
KB_DB_NAME=wordpress_kb
KB_DB_USER=wp_kb
KB_DB_PASSWORD=CHANGE_ME_KB_DB_PASSWORD
FAMILY_DB_NAME=wordpress_family
FAMILY_DB_USER=wp_family
FAMILY_DB_PASSWORD=CHANGE_ME_FAMILY_DB_PASSWORD

# Initial WordPress admin and publisher accounts.
# These are used only by scripts/init-wordpress.sh.
WP_ADMIN_USER=site-admin
WP_ADMIN_EMAIL=admin@example.com
WP_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
WP_PUBLISHER_USER=codex-publisher
WP_PUBLISHER_EMAIL=codex-publisher@example.com
WP_PUBLISHER_PASSWORD=CHANGE_ME_PUBLISHER_PASSWORD

# Aliyun DNS DDNS.
# Cloudflare Tunnel deployment does not use these values.
# Use a restricted RAM user with AliDNS record read/update permissions only.
# This script updates A records. If kb/family are CNAME records, either:
#   1) point them to another A record that is updated by DDNS, and put that RR here; or
#   2) leave these keys empty and skip the DDNS timer.
ALIYUN_ACCESS_KEY_ID=CHANGE_ME
ALIYUN_ACCESS_KEY_SECRET=CHANGE_ME
ALIYUN_DOMAIN_NAME=example.com
ALIYUN_RR_LIST=kb,family
ALIYUN_TTL=600

# Publishing API credentials.
# Fill these after scripts/init-wordpress.sh prints application passwords.
WP_KB_API_USER=codex-publisher
WP_KB_APP_PASSWORD=CHANGE_ME_AFTER_INIT
WP_FAMILY_API_USER=codex-publisher
WP_FAMILY_APP_PASSWORD=CHANGE_ME_AFTER_INIT

# Backup behavior.
BACKUP_DIR=./backups
# Optional remote destination, for example:
#   user@nas:/volume1/backups/home-wordpress
#   /mnt/offsite/home-wordpress-backups
OFFSITE_BACKUP_TARGET=
# Set to 1 only if the offsite target should mirror local retention deletes.
OFFSITE_BACKUP_DELETE=0
BACKUP_RETENTION_DAYS=30
